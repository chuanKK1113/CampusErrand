<view class="container">
  <text class="page-title">编辑资料</text>

  <view class="card">
    <!-- 头像区域 -->
    <view class="avatar-section" bindtap="onChooseAvatar">
      <image class="avatar-image" src="{{avatarUrl || defaultAvatar}}" mode="aspectFill" />
      <view class="avatar-overlay">
        <text class="avatar-change-text">点击更换头像</text>
      </view>
    </view>

    <!-- 昵称修改 -->
    <view class="form-group">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" maxlength="50" />
    </view>

    <view class="form-group">
      <text class="form-label">用户名</text>
      <input class="form-input" value="{{username}}" disabled style="background:#eee;color:#999" />
    </view>

    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="form-input" value="{{phone}}" disabled style="background:#eee;color:#999" />
    </view>

    <!-- 按钮 -->
    <button class="btn-primary" bindtap="onSave" loading="{{loading}}">保存修改</button>
    <button class="btn-outline" bindtap="onBack">取消</button>
  </view>
</view>
