/* 个人中心 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD) !important;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.profile-role-badge {
  padding: 8rpx 32rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #fff;
}

/* 菜单项 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 8rpx;
  border-bottom: 2rpx solid #f5f5f5;
  font-size: 30rpx;
  color: #333;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}
