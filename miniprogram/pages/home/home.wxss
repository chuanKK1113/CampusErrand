/* 欢迎卡片 */
.welcome-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90D9, #357ABD) !important;
}

.welcome-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.welcome-avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  overflow: hidden;
}

.welcome-info {
  display: flex;
  flex-direction: column;
}

.welcome-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.welcome-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 操作网格 */
.action-grid {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-icon-orange { background: #fff3e0; }
.action-icon-blue { background: #e3f2fd; }
.action-icon-green { background: #e8f5e9; }

.action-text {
  font-size: 26rpx;
  color: #555;
}

/* 统计网格 */
.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #2c3e50;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 区头 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #4A90D9;
}

/* 迷你订单项 */
.order-mini-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.order-mini-item:last-child {
  border-bottom: none;
}

.order-mini-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.order-mini-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.order-mini-desc {
  font-size: 26rpx;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.order-mini-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-mini-price {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: 700;
}

.order-mini-time {
  font-size: 22rpx;
  color: #bbb;
}

.empty-text {
  text-align: center;
  padding: 40rpx 0;
  color: #bbb;
  font-size: 28rpx;
}
