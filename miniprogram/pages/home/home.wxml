<view class="container">
  <!-- 用户欢迎 -->
  <view class="card welcome-card">
    <view wx:if="{{!avatarFullUrl}}" class="welcome-avatar">{{userInfo.name ? userInfo.name[0] : '?'}}</view>
    <image wx:else class="welcome-avatar-img" src="{{avatarFullUrl}}" mode="aspectFill" />
    <view class="welcome-info">
      <text class="welcome-name">{{userInfo.name || '用户'}}</text>
      <text class="welcome-role">{{roleText}}</text>
    </view>
  </view>

  <!-- 需求方首页 -->
  <block wx:if="{{userInfo.role === 'requester'}}">
    <!-- 快捷操作 -->
    <view class="card">
      <text class="section-title">快捷操作</text>
      <view class="action-grid">
        <view class="action-item" bindtap="onCreateOrder">
          <view class="action-icon action-icon-orange">📝</view>
          <text class="action-text">发布订单</text>
        </view>
        <view class="action-item" bindtap="onMyOrders">
          <view class="action-icon action-icon-blue">📋</view>
          <text class="action-text">我的订单</text>
        </view>
        <view class="action-item" bindtap="onMyReviews">
          <view class="action-icon action-icon-green">⭐</view>
          <text class="action-text">我的评价</text>
        </view>
      </view>
    </view>

    <!-- 最近订单 -->
    <view class="card">
      <view class="section-header">
        <text class="section-title">最近订单</text>
        <text class="section-more" bindtap="onMyOrders">查看更多 ›</text>
      </view>
      <block wx:if="{{recentOrders.length > 0}}">
        <view class="order-mini-item" wx:for="{{recentOrders}}" wx:key="id" bindtap="onOrderDetail" data-id="{{item.id}}">
          <view class="order-mini-top">
            <text class="order-mini-type">{{item.type}}</text>
            <text class="list-item-status status-{{item.status === '待接单' ? 'pending' : item.status === '配送中' ? 'delivering' : item.status === '已完成' ? 'completed' : 'cancelled'}}">{{item.status}}</text>
          </view>
          <text class="order-mini-desc">{{item.details}}</text>
          <view class="order-mini-bottom">
            <text class="order-mini-price">¥{{item.reward}}</text>
            <text class="order-mini-time">{{item.created_at}}</text>
          </view>
        </view>
      </block>
      <view wx:else class="empty-text">暂无订单</view>
    </view>
  </block>

  <!-- 配送员首页 -->
  <block wx:if="{{userInfo.role === 'delivery'}}">
    <!-- 数据概览 -->
    <view class="card">
      <text class="section-title">我的数据</text>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-value">{{stats.completed_count || 0}}</text>
          <text class="stat-label">已完成</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">¥{{stats.total_income || 0}}</text>
          <text class="stat-label">总收入</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{userInfo.rating || '暂无'}}</text>
          <text class="stat-label">评分</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="card">
      <text class="section-title">快捷操作</text>
      <view class="action-grid">
        <view class="action-item" bindtap="onBrowseOrders">
          <view class="action-icon action-icon-green">🔍</view>
          <text class="action-text">浏览订单</text>
        </view>
        <view class="action-item" bindtap="onMyDeliveries">
          <view class="action-icon action-icon-blue">🚚</view>
          <text class="action-text">我的配送</text>
        </view>
        <view class="action-item" bindtap="onIncome">
          <view class="action-icon action-icon-orange">💰</view>
          <text class="action-text">收入统计</text>
        </view>
      </view>
    </view>

    <!-- 待配送订单 -->
    <view class="card">
      <text class="section-title">配送中的订单</text>
      <block wx:if="{{activeDeliveries.length > 0}}">
        <view class="order-mini-item" wx:for="{{activeDeliveries}}" wx:key="id" bindtap="onOrderDetail" data-id="{{item.id}}">
          <view class="order-mini-top">
            <text class="order-mini-type">{{item.type}}</text>
            <text class="list-item-status status-delivering">配送中</text>
          </view>
          <text class="order-mini-desc">{{item.details}}</text>
          <view class="order-mini-bottom">
            <text class="order-mini-price">¥{{item.reward}}</text>
            <text class="order-mini-time">{{item.pickup}} → {{item.dropoff}}</text>
          </view>
        </view>
      </block>
      <view wx:else class="empty-text">暂无配送中的订单</view>
    </view>
  </block>
</view>
