/* 收入统计 */
.income-summary {
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  padding: 48rpx 32rpx;
}

.income-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.income-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
}

.income-money {
  color: #ffd700;
}

.income-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

.income-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.3);
}
