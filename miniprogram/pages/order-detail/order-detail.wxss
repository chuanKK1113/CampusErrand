/* 状态卡片 */
.status-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}

.status-card-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.status-card-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.status-bg-pending { background: #f0ad4e !important; }
.status-bg-delivering { background: #5bc0de !important; }
.status-bg-completed { background: #5cb85c !important; }
.status-bg-cancelled { background: #999 !important; }

/* 信息行 */
.info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #888;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.info-price {
  color: #e74c3c;
  font-weight: 700;
  font-size: 32rpx;
}

/* 操作按钮区 */
.action-card {
  border: 2rpx dashed #e0e0e0;
}
