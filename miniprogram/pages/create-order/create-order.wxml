<view class="container">
  <text class="page-title">发布订单</text>

  <view class="card">
    <view class="form-group">
      <text class="form-label">订单类型</text>
      <picker class="form-picker" range="{{types}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view>{{types[typeIndex]}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">详细描述</text>
      <textarea class="form-textarea" placeholder="请描述需要跑腿的具体内容" value="{{details}}" bindinput="onInput" data-field="details" />
    </view>

    <view class="form-group">
      <text class="form-label">取件地点</text>
      <input class="form-input" placeholder="如：菜鸟驿站" value="{{pickup}}" bindinput="onInput" data-field="pickup" />
    </view>

    <view class="form-group">
      <text class="form-label">送达地点</text>
      <input class="form-input" placeholder="如：学苑公寓" value="{{dropoff}}" bindinput="onInput" data-field="dropoff" />
    </view>

    <view class="form-group">
      <text class="form-label">配送费（¥）</text>
      <input class="form-input" type="digit" placeholder="请输入金额" value="{{reward}}" bindinput="onInput" data-field="reward" />
    </view>

    <view class="form-group">
      <text class="form-label">备注（可选）</text>
      <input class="form-input" placeholder="其他需要说明的事项" value="{{note}}" bindinput="onInput" data-field="note" />
    </view>

    <button class="btn-primary" bindtap="onSubmit" loading="{{loading}}">发布订单</button>
  </view>
</view>
