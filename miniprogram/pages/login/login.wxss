.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f0fe 0%, #f5f5f5 100%);
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.login-logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
}

.login-form {
  width: 100%;
  padding: 40rpx;
}

.login-footer {
  margin-top: 40rpx;
}

.login-footer-text {
  font-size: 24rpx;
  color: #bbb;
}
