<view class="container">
  <text class="page-title">注册账号</text>

  <view class="card">
    <view class="form-group">
      <text class="form-label">用户名</text>
      <input class="form-input" placeholder="请输入用户名（2-50个字符）" value="{{username}}" bindinput="onInput" data-field="username" />
    </view>
    <view class="form-group">
      <text class="form-label">密码</text>
      <input class="form-input" type="password" placeholder="请输入密码（至少4位）" value="{{password}}" bindinput="onInput" data-field="password" />
    </view>
    <view class="form-group">
      <text class="form-label">真实姓名</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" value="{{phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-group">
      <text class="form-label">学号（可选）</text>
      <input class="form-input" placeholder="请输入学号" value="{{student_id}}" bindinput="onInput" data-field="student_id" />
    </view>
    <view class="form-group">
      <text class="form-label">角色</text>
      <picker class="form-picker" range="{{roles}}" value="{{roleIndex}}" bindchange="onRoleChange">
        <view>{{roles[roleIndex] || '请选择角色'}}</view>
      </picker>
    </view>

    <button class="btn-primary" bindtap="onRegister" loading="{{loading}}">注 册</button>
    <button class="btn-outline" bindtap="onBack">返回登录</button>
  </view>
</view>
