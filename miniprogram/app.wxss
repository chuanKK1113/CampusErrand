/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
  margin: 16rpx 0;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-danger {
  background: #e74c3c;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
  margin: 16rpx 0;
}

.btn-outline {
  background: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 12rpx;
  padding: 22rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
  margin: 16rpx 0;
}

/* 表单 */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 30rpx;
  color: #555;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4A90D9;
}

.form-textarea {
  width: 100%;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  min-height: 160rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background: #fff3cd;
  color: #856404;
}

.status-delivering {
  background: #cce5ff;
  color: #004085;
}

.status-completed {
  background: #d4edda;
  color: #155724;
}

.status-cancelled {
  background: #f8d7da;
  color: #721c24;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state text {
  font-size: 32rpx;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 60rpx 0;
}

/* 列表项 */
.list-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.list-item:active {
  background: #f8f9fa;
}

.list-item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}

.list-item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.list-item-price {
  font-size: 36rpx;
  color: #e74c3c;
  font-weight: 700;
}

.list-item-status {
  font-size: 26rpx;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #444;
  margin-bottom: 20rpx;
}
